{
  "name": "shaurmechka",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "start": "node ../server/index.js",
    "postinstall": "npm rebuild sqlite3 --build-from-source --update-binary",
    "render-build": "npm install --build-from-source=sqlite3 && npm rebuild sqlite3 --build-from-source --update-binary",
    "sass:build": "sass scss:../css --no-source-map",
    "sass:watch": "sass --watch scss:../css --no-source-map",
    "server": "node ../server/index.js"
  },
  "devDependencies": {
    "sass": "^1.61.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "sqlite3": "^5.1.7"
  }
}
